# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (use the pooled
# "Transaction" string for DATABASE_URL and the direct string for DIRECT_URL).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# The owner's login email — the ONLY account allowed into the admin dashboard.
# Must exactly match the email of the user you created in Supabase → Auth.
# If this is unset or different, sign-in succeeds but you bounce back to /login.
OWNER_EMAIL="you@example.com"

# ── Stripe (online payments) ─────────────────────────────────────────────────
# Optional: without keys, cash/Venmo/CashApp payment logging still works.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Google Maps (route optimization) ─────────────────────────────────────────
# Optional: without a key, routes are optimized with built-in geometry
# (haversine nearest-neighbor + 2-opt). With a key, real drive times from the
# Distance Matrix API are used and the interactive map is enabled.
# Enable: Maps JavaScript API, Geocoding API, Distance Matrix API.
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Email notifications (Resend) ─────────────────────────────────────────────
# Optional: without a key, emails are logged to the console + notifications_log.
RESEND_API_KEY=""
EMAIL_FROM="Garden State Water <delivery@yourdomain.com>"

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Optional: without keys, SMS falls back to email / console logging.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret used to authenticate Vercel Cron requests to /api/cron/daily
CRON_SECRET="change-me"
