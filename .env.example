# Garden State Water — environment variables
#
# Format rules (they matter — a malformed value took production down once):
#   • No quotes around values. `KEY=value`, never `KEY="value"`.
#     Quotes happen to parse in a local .env, but pasting a quoted value into
#     the Vercel dashboard stores the quotes literally and breaks URL parsing.
#   • No leading/trailing spaces.
#   • URLs must include the protocol (https://…).
#
# In Vercel (Settings → Environment Variables) paste ONLY the raw value, and
# redeploy afterwards — env changes never apply to existing builds, and
# NEXT_PUBLIC_* values are baked in at build time.

# ── Database (Supabase Postgres) — REQUIRED ─────────────────────────────────
# Supabase → Connect (top of the dashboard) → copy the POOLER strings.
#   DATABASE_URL = "Transaction" pooler (port 6543) + pgbouncer params
#   DIRECT_URL   = "Session" pooler (port 5432) — used for migrations
# ⚠ The pooler username is postgres.[PROJECT-REF] — the suffix is required.
# ⚠ URL-encode special characters in the password (@ → %40, # → %23, …).
# ⚠ Don't use the direct db.[PROJECT-REF].supabase.co host from Vercel — it's
#   IPv6-only and unreachable from serverless functions.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── Supabase Auth — REQUIRED in production ──────────────────────────────────
# Supabase → Project Settings → API. Leave both unset locally for open dev
# mode (no auth wall). If either is set, both must be set and valid.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The owner's login email — the ONLY account allowed into the admin dashboard.
# Must exactly match the email of the user you created in Supabase → Auth.
# If this is unset or different, sign-in succeeds but you bounce back to /login.
OWNER_EMAIL=you@example.com

# ── App URL — REQUIRED in production ────────────────────────────────────────
# Used for Stripe redirect URLs and links in customer emails.
# Production: https://gardenstatewater.com   Local: http://localhost:3000
# (A localhost value is ignored in production builds as a safety net.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authenticate Vercel Cron requests to /api/cron/daily
CRON_SECRET=change-me

# ── Stripe (optional — online payments) ─────────────────────────────────────
# Without keys, cash/Venmo/CashApp payment logging still works.
# STRIPE_WEBHOOK_SECRET comes from the webhook endpoint you create at
# https://<your-domain>/api/stripe/webhook (event: checkout.session.completed).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google Maps (optional — route optimization) ─────────────────────────────
# Without a key, routes are optimized with built-in geometry (haversine
# nearest-neighbor + 2-opt). With a key, real drive times from the Distance
# Matrix API are used and the interactive map is enabled.
# Enable: Maps JavaScript API, Geocoding API, Distance Matrix API.
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Email notifications (Resend, optional) ──────────────────────────────────
# Without a key, emails are logged to the console + notifications_log.
RESEND_API_KEY=
EMAIL_FROM=Garden State Water <delivery@yourdomain.com>

# ── SMS (Twilio, optional) ──────────────────────────────────────────────────
# Without keys, SMS falls back to email / console logging.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
