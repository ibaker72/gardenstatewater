// Garden State Water — full business schema
// Postgres (Supabase in production, local Postgres in dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  CUSTOMER
}

enum AccountType {
  RESIDENTIAL
  COMMERCIAL
  EVENT
}

enum SubscriptionPlan {
  WEEKLY
  BIWEEKLY
  MONTHLY
  ON_DEMAND
}

enum CustomerStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  CHURNED
}

enum OrderStatus {
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  PAID
  CANCELLED
}

enum ProductType {
  JUG_REFILL
  JUG_PURCHASE
  DISPENSER_RENTAL
  BOTTLE_CASE
  DELIVERY_FEE
  OTHER
}

enum PaymentMethod {
  CASH
  VENMO
  CASHAPP
  ZELLE
  STRIPE
  CHECK
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum NotificationType {
  DELIVERY_REMINDER
  PAYMENT_REMINDER
  OWNER_DAILY_SUMMARY
  LOYALTY
  SUSPENSION_WARNING
  INVOICE
  PORTAL_REQUEST
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
  CONSOLE
}

enum CommChannel {
  CALL
  TEXT
  EMAIL
  IN_PERSON
  NOTE
}

// ── Auth / users ────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  supabaseId String?   @unique
  email      String    @unique
  name       String?
  role       Role      @default(CUSTOMER)
  customer   Customer?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("users")
}

// ── Customers (CRM) ─────────────────────────────────────────────────────────

model Customer {
  id               String           @id @default(cuid())
  userId           String?          @unique
  user             User?            @relation(fields: [userId], references: [id])
  name             String
  email            String?
  phone            String?
  address          String
  city             String?
  state            String?          @default("NJ")
  zip              String?
  lat              Float?
  lng              Float?
  deliveryNotes    String? // "leave at back gate"
  accountType      AccountType      @default(RESIDENTIAL)
  plan             SubscriptionPlan @default(ON_DEMAND)
  planJugs         Int              @default(2) // jugs per scheduled delivery
  preferredDay     Int? // 0=Sun..6=Sat, for subscription scheduling
  status           CustomerStatus   @default(ACTIVE)
  suspendedAt      DateTime?
  suspensionNote   String?
  zoneId           String?
  zone             Zone?            @relation(fields: [zoneId], references: [id])
  jugsWithCustomer Int              @default(0) // our jugs currently at their site
  jugDeposits      Int              @default(0) // jugs they've bought outright
  dispenserRental  Boolean          @default(false) // renting a dispenser (monthly fee)
  paymentPref      PaymentMethod? // how they usually like to pay
  portalToken      String           @unique @default(cuid())
  portalAccess     Boolean          @default(true) // owner can switch the portal off per customer
  portalPin        String? // sha256(customerId:pin) — fallback login for customers without phone/email
  portalLastLoginAt DateTime?
  birthday         DateTime?
  referralCode     String?          @unique // shareable "refer a neighbor" code, e.g. GSW-A1B2C3
  referredById     String?
  referredBy       Customer?        @relation("CustomerReferrals", fields: [referredById], references: [id])
  referrals        Customer[]       @relation("CustomerReferrals")
  startedAt        DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  orders    Order[]
  invoices  Invoice[]
  payments  Payment[]
  commLogs  CommLog[]
  requests  PortalRequest[]
  notified  NotificationLog[]
  portalSessions PortalSession[]
  portalLoginCodes PortalLoginCode[]
  referralCredits ReferralCredit[]

  @@index([zoneId])
  @@index([status])
  @@index([plan])
  @@map("customers")
}

model CommLog {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel    CommChannel @default(NOTE)
  note       String
  createdAt  DateTime    @default(now())

  @@index([customerId])
  @@map("comm_logs")
}

// A logged-in portal session (30 days). The cookie holds the raw token;
// only its sha256 lives here, so a database leak can't hijack sessions.
model PortalSession {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([customerId])
  @@map("portal_sessions")
}

// One-time 6-digit login codes (10-minute expiry, 5 verify attempts,
// max 5 codes per customer per hour).
model PortalLoginCode {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  codeHash   String
  channel    String // sms | email | console
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@map("portal_login_codes")
}

// Requests submitted from the customer portal (extra delivery, pause, contact update)
model PortalRequest {
  id            String    @id @default(cuid())
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind          String // EXTRA_DELIVERY | PAUSE | RESUME | CONTACT_UPDATE | OTHER
  detail        String?
  requestedDate DateTime? // structured, so approving can create the order directly
  jugs          Int?
  resolved      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([customerId])
  @@map("portal_requests")
}

// ── Zones & pricing ─────────────────────────────────────────────────────────

model Zone {
  id           String     @id @default(cuid())
  name         String     @unique // "Zone 1"
  description  String?
  deliveryFee  Float      @default(0)
  deliveryDays Int[]      @default([]) // weekdays served, 0=Sun..6=Sat; empty = every day
  zips         String[]   @default([]) // zip codes mapped to this zone
  color       String?    @default("#1c94bd")
  customers   Customer[]
  serviceZips ServiceZip[]
  createdAt   DateTime   @default(now())

  @@map("zones")
}

// The public serviceable-ZIP list: powers the marketing site's ZIP checker,
// region grid, and the per-town SEO landing pages. Owner-managed from
// Settings → Website; a ZIP here means "we deliver" even before it is wired
// to an operational zone.
model ServiceZip {
  zip       String   @id // 5-digit ZIP
  town      String // "Morristown"
  state     String   @default("NJ") // NJ | NY
  region    String // "Morris & Essex", "Westchester", …
  slug      String // town landing-page slug, e.g. "morristown-nj" (shared by the town's ZIPs)
  zoneId    String?
  zone      Zone?    @relation(fields: [zoneId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([slug])
  @@index([region])
  @@map("service_zips")
}

// Visitors outside the service area who asked to be texted when we arrive.
// This list drives expansion planning — visible in Settings → Website.
model WaitlistEntry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  zip       String
  town      String? // resolved town when the ZIP is recognized
  source    String   @default("homepage")
  contacted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([zip])
  @@map("waitlist_entries")
}

// Marketing offers and the seasonal banner, editable from Settings → Website.
// slot "offer" renders in the Deals section; slot "banner" is the strip above
// the header (first active row wins).
model Deal {
  id          String   @id @default(cuid())
  slot        String   @default("offer") // offer | banner
  title       String
  description String?
  badge       String? // "Launch offer", "Limited time", …
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("deals")
}

// The public pricing tiers shown on gardenstatewater.com. Prices and
// visibility are owner-editable (Settings → Website); the signup flow maps a
// tier onto the operational subscription fields at checkout.
model SitePlan {
  id             String   @id @default(cuid())
  key            String   @unique // one_time | hydrate | family | office
  name           String
  tagline        String?
  monthlyPrice   Float // for one_time this is the per-jug price
  priceUnit      String   @default("month") // "month" | "jug"
  jugsPerMonth   Int
  badge          String? // "Most Popular"
  features       String[] @default([])
  isSubscription Boolean  @default(true)
  customQuote    Boolean  @default(false) // office: "starts at" + contact CTA
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("site_plans")
}

// "Refer a neighbor, both get a free jug" ledger. A row is one free-jug
// credit; redeemedAt is set when the owner applies it to a delivery.
model ReferralCredit {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jugs       Int       @default(1)
  reason     String // "Referred Maria A." / "Signed up with GSW-A1B2C3"
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@map("referral_credits")
}

// Single-row table of every configurable price / business setting.
model PricingConfig {
  id                    String   @id @default("default")
  jugRefillPrice        Float    @default(8)
  jugPurchasePrice      Float    @default(35)
  dispenserRentalPrice  Float    @default(7) // per month
  bottleCasePrice       Float    @default(8.99) // case of 16.9oz bottles (delivery add-on)
  flatDeliveryFee       Float    @default(0) // used when customer has no zone
  // Public storefront prices (Settings → Website / pricing page)
  oneTimeJugPrice          Float @default(11.99) // one-time delivery, per jug
  oneTimeDeliveryFee       Float @default(4.99) // delivery fee on one-time orders
  dispenserPurchasePrice   Float @default(129) // buy a dispenser outright
  jugDepositPrice          Float @default(10) // refundable first-time bottle deposit
  annualFreeMonths         Int   @default(1) // pay yearly, get N months free
  firstDeliveryDiscountPct Float @default(50) // new-subscription launch offer
  weeklyDiscountPct     Float    @default(10)
  biweeklyDiscountPct   Float    @default(5)
  monthlyDiscountPct    Float    @default(0)
  bulkBuyQty            Int      @default(10) // buy N...
  bulkFreeQty           Int      @default(1) // ...get M free
  costPerGallon         Float    @default(0.35) // supplier cost
  gasCostPerMile        Float    @default(0.20)
  laborCostPerHour      Float    @default(0)
  targetMarginPct       Float    @default(60)
  lowStockThreshold     Int      @default(20) // jugs in stock alert level
  businessName          String   @default("Garden State Water")
  businessPhone         String?
  businessEmail         String?
  businessAddress       String?
  overdueSuspendDays    Int      @default(45)
  loyaltyMonths         Int      @default(12) // customers older than this get loyalty messages
  loyaltyEnabled        Boolean  @default(true)
  autoSuspendEnabled    Boolean  @default(true)
  updatedAt             DateTime @updatedAt

  @@map("pricing_config")
}

// Real customer quotes the owner curates in Settings — shown on the
// public landing page. Nothing renders until the owner adds some.
model Testimonial {
  id        String   @id @default(cuid())
  name      String // "Maria A., Newark"
  quote     String
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model CompetitorPrice {
  id             String   @id @default(cuid())
  competitor     String // "Competitor A"
  jugRefill      Float?
  jugPurchase    Float?
  dispenserRent  Float?
  bottleCase     Float?
  deliveryFee    Float?
  notes          String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@map("competitor_prices")
}

// ── Orders & deliveries ─────────────────────────────────────────────────────

model Order {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  status         OrderStatus   @default(SCHEDULED)
  deliveryDate   DateTime      @db.Date
  deliveredAt    DateTime?
  instructions   String?
  paymentMethod  PaymentMethod?
  jugsReturned   Int           @default(0) // empties picked up on this delivery
  subtotal       Float         @default(0)
  discount       Float         @default(0)
  deliveryFee    Float         @default(0)
  total          Float         @default(0)
  fromSubscription Boolean     @default(false)
  items          OrderItem[]
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  routeStops     RouteStop[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([customerId])
  @@index([deliveryDate])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productType ProductType
  description String?
  quantity    Int         @default(1)
  unitPrice   Float
  lineTotal   Float

  @@index([orderId])
  @@map("order_items")
}

// ── Inventory ───────────────────────────────────────────────────────────────

model InventoryItem {
  id               String   @id @default(cuid())
  sku              String   @unique // "JUG_5GAL", "CAPS", "SEALS", ...
  name             String
  category         String   @default("consumable") // jug | consumable | equipment
  quantity         Int      @default(0)
  unit             String   @default("unit")
  unitCost         Float    @default(0)
  reorderThreshold Int      @default(0)
  reorderAmount    Int      @default(0)
  notes            String?
  updatedAt        DateTime @updatedAt
  movements        InventoryMovement[]

  @@map("inventory")
}

model InventoryMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  delta     Int // +in / -out
  reason    String // "delivery", "return", "purchase", "lost", "damaged", "adjustment"
  reference String? // order id, purchase id...
  createdAt DateTime      @default(now())

  @@index([itemId])
  @@map("inventory_movements")
}

model Supplier {
  id        String             @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  purchases SupplierPurchase[]
  createdAt DateTime           @default(now())

  @@map("suppliers")
}

model SupplierPurchase {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  date          DateTime @default(now())
  gallons       Float    @default(0)
  costPerGallon Float    @default(0)
  otherCost     Float    @default(0) // caps, seals bought in same run
  total         Float    @default(0)
  notes         String?

  @@index([supplierId])
  @@map("supplier_purchases")
}

// ── Invoicing & payments ────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  number          Int           @unique @default(autoincrement())
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  subtotal        Float         @default(0)
  discount        Float         @default(0)
  deliveryFees    Float         @default(0)
  total           Float         @default(0)
  amountPaid      Float         @default(0)
  memo            String?
  stripeSessionId String?
  sentAt          DateTime?
  orders          Order[]
  payments        Payment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id         String        @id @default(cuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  invoiceId  String?
  invoice    Invoice?      @relation(fields: [invoiceId], references: [id])
  method     PaymentMethod
  amount     Float
  reference  String? // Venmo handle, Stripe payment intent, check #...
  note       String?
  receivedAt DateTime      @default(now())
  createdAt  DateTime      @default(now())

  @@index([customerId])
  @@index([invoiceId])
  @@map("payments")
}

// ── Routes ──────────────────────────────────────────────────────────────────

model Route {
  id            String      @id @default(cuid())
  date          DateTime    @db.Date
  name          String?
  totalMiles    Float?
  totalMinutes  Float?
  optimizedWith String?     @default("haversine") // haversine | google
  startAddress  String?
  stops         RouteStop[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([date])
  @@map("routes")
}

model RouteStop {
  id          String    @id @default(cuid())
  routeId     String
  route       Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sequence    Int
  milesFromPrev Float?
  minutesFromPrev Float?
  completedAt DateTime?

  @@unique([routeId, orderId])
  @@index([routeId])
  @@map("route_stops")
}

// ── Notifications ───────────────────────────────────────────────────────────

model NotificationLog {
  id         String              @id @default(cuid())
  customerId String?
  customer   Customer?           @relation(fields: [customerId], references: [id])
  type       NotificationType
  channel    NotificationChannel @default(EMAIL)
  recipient  String
  subject    String?
  body       String
  success    Boolean             @default(true)
  error      String?
  createdAt  DateTime            @default(now())

  @@index([customerId])
  @@index([type])
  @@map("notifications_log")
}
